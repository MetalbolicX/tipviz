{
  "name": "tipviz",
  "version": "2.1.0",
  "description": "Framework-agnostic a tooltip Web Components for modern web applications. Focused on data visualization.",
  "type": "module",
  "main": "./dist/index.umd.js",
  "types": "./dist/index.d.mts",
  "homepage": "https://metalbolicx.github.io/tipviz/",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "tooltip",
    "visualization",
    "typescript",
    "vanilla-js"
  ],
  "scripts": {
    "docs": "docsify serve docs",
    "build": "vite build",
    "dev": "vite",
    "tsdown:build": "tsdown"
  },
  "author": {
    "name": "José Martínez Santana"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MetalbolicX/tipviz.git"
  },
  "bugs": {
    "url": "https://github.com/MetalbolicX/tipviz/issues"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "module": "./dist/index.mjs"
}
